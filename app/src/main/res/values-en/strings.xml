    <string name="shizuku_help_step4_desc">After authorization, return to Baozi. The status card will show \"Shizuku Connected\"</string>

    <!-- Overlay Help -->
    <string name="overlay_why">Why is overlay permission needed?</string>
    <string name="overlay_reason">Baozi needs to display an overlay during task execution to:</string>
    <string name="overlay_feature1">Show current execution progress</string>
    <string name="overlay_feature2">Provide a stop button to interrupt tasks anytime</string>
    <string name="overlay_feature3">Display status information above other apps</string>
    <string name="overlay_how">How to enable?</string>
    <string name="overlay_how_desc">1. You\'ll be prompted when executing a task\n2. Or go to: Settings > Apps > Baozi > Overlay permission\n3. Enable \"Allow display over other apps\"</string>
    <string name="overlay_privacy">Privacy &amp; Security</string>
    <string name="overlay_privacy_desc">The overlay is only shown during task execution and does not collect any personal information. It automatically disappears after the task is complete.</string>

