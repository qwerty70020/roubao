    <!-- Shizuku Help -->
    <string name="shizuku_help_step1_title">Download Shizuku</string>
    <string name="shizuku_help_step1_desc">Download Shizuku from Google Play or GitHub\n\n• Google Play: Search \"Shizuku\"\n• GitHub: github.com/RikkaApps/Shizuku</string>
    <string name="shizuku_help_step2_title">Start Shizuku</string>
    <string name="shizuku_help_step2_desc">Open Shizuku and choose a startup method:\n\n• Wireless debugging (recommended): Requires Android 11+, enable wireless debugging in developer options\n• Connect to computer: Start via ADB command</string>
    <string name="shizuku_help_step3_title">Authorize Baozi</string>
