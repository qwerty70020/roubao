    <!-- Capabilities - Agents -->
    <string name="agent_manager_role">Planner</string>
    <string name="agent_manager_desc">Understands user intent, builds a high-level execution plan, and tracks task progress.</string>
    <string name="agent_manager_r1">Analyze the user request and understand real intent</string>
    <string name="agent_manager_r2">Break a complex task into executable sub-goals</string>
    <string name="agent_manager_r3">Plan the execution order and steps</string>
    <string name="agent_manager_r4">Adjust the plan dynamically based on feedback</string>
    <string name="agent_executor_role">Executor</string>
    <string name="agent_executor_desc">Analyzes the current screen state and decides concrete UI actions.</string>
    <string name="agent_executor_r1">Analyze screenshots and understand UI elements</string>
    <string name="agent_executor_r2">Pick the next step based on the plan</string>
    <string name="agent_executor_r3">Decide taps, swipes, text input and other actions</string>
    <string name="agent_executor_r4">Produce precise action coordinates and parameters</string>
    <string name="agent_reflector_role">Reflector</string>
    <string name="agent_reflector_desc">Evaluates the result of each action and whether it succeeded.</string>
    <string name="agent_reflector_r1">Compare screens before and after the action</string>
    <string name="agent_reflector_r2">Decide whether the expected effect was achieved</string>
    <string name="agent_reflector_r3">Spot anomalies (dialogs, errors)</string>
    <string name="agent_reflector_r4">Provide feedback to adjust the next strategy</string>
    <string name="agent_notetaker_role">Notetaker</string>
    <string name="agent_notetaker_desc">Records key information during execution so other agents can reuse it.</string>
