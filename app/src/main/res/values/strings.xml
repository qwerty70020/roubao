    <!-- Shizuku Help -->
    <string name="shizuku_help_step1_title">下载 Shizuku</string>
    <string name="shizuku_help_step1_desc">从 Google Play 或 GitHub 下载 Shizuku 应用\n\n• Google Play: 搜索 \"Shizuku\"\n• GitHub: github.com/RikkaApps/Shizuku</string>
    <string name="shizuku_help_step2_title">启动 Shizuku</string>
    <string name="shizuku_help_step2_desc">打开 Shizuku 应用，根据您的设备选择启动方式：\n\n• 无线调试（推荐）：需要 Android 11+，在开发者选项中开启无线调试\n• 连接电脑：通过 ADB 命令启动</string>
    <string name="shizuku_help_step3_title">授权肉包</string>
    <string name="shizuku_help_step3_desc">在 Shizuku 的「应用管理」中找到肉包 Autopilot，点击授权按钮</string>
    <string name="shizuku_help_step4_title">开始使用</string>
    <string name="shizuku_help_step4_desc">授权完成后，返回肉包应用，状态卡片会显示「Shizuku 已连接」</string>

    <!-- Overlay Help -->
    <string name="overlay_why">为什么需要悬浮窗权限？</string>
    <string name="overlay_reason">肉包在执行任务时需要显示悬浮窗来：</string>
    <string name="overlay_feature1">显示当前执行进度</string>
    <string name="overlay_feature2">提供停止按钮，随时中断任务</string>
    <string name="overlay_feature3">在其他应用上方显示状态信息</string>
    <string name="overlay_how">如何开启？</string>
    <string name="overlay_how_desc">1. 点击执行任务时会自动提示\n2. 或前往：设置 > 应用 > 肉包 > 悬浮窗权限\n3. 开启「允许显示在其他应用上层」</string>
    <string name="overlay_privacy">隐私安全</string>
    <string name="overlay_privacy_desc">悬浮窗仅在任务执行期间显示，不会收集任何个人信息。任务完成后悬浮窗会自动消失。</string>

